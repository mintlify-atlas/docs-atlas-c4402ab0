  "keyFeatures": [
    "Continuous token swaps with time-based distribution",
    "Dynamic community-driven price discovery",
    "Multi-phase stream lifecycle (Waiting, Bootstrapping, Active, Ended, Finalized)",
    "Automated liquidity pool creation on Osmosis",
    "Optional vesting schedules for creators and subscribers",
    "Threshold-based stream cancellation protection",
    "DAO governance for protocol parameters",
    "Exit fees and creation fees management"
  ],
  "publicApiSurface": [
    "ExecuteMsg::CreateStream",
